{
  "manifest_version": 3,
  "name": "AEO/GEO Audit Tool - AI readiness check",
  "version": "1.0.0",
  "description": "Quick AI readiness audit for any webpage. Check if your page is optimized for AI platforms like ChatGPT, Claude, and Perplexity.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "AEO/GEO Audit Tool - AI readiness check"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "jsPDF.min.js"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}

