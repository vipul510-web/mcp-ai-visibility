# ---------------------------------------------------------------------------
# AEO Visibility MCP Server — Environment Variables
# Copy this file to .env and fill in your values
# ---------------------------------------------------------------------------

# Required: Perplexity API key for AI visibility checking
# Get one at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: OpenAI API key for additional AI visibility checks (ChatGPT)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Anthropic API key for Claude-based checks
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# HTTP Server settings (only needed when running in HTTP mode: npm run start:http)
# ---------------------------------------------------------------------------

# Port for the HTTP MCP server (default: 3000)
PORT=3000

# Comma-separated list of valid API keys for your users
# Users get these from sellonllm.com
# Example: VALID_API_KEYS=key_abc123,key_def456
VALID_API_KEYS=

# Secret for validating API keys (used if you generate keys via HMAC)
API_KEY_SECRET=change-this-to-a-random-secret

# ---------------------------------------------------------------------------
# Optional: Crawling behavior
# ---------------------------------------------------------------------------

# Max pages to crawl per site analysis (default: 10)
MAX_CRAWL_PAGES=10

# Request timeout in ms for website crawling (default: 10000)
CRAWL_TIMEOUT_MS=10000

# Rate limit: max Perplexity API calls per minute (default: 10)
PERPLEXITY_RPM=10
