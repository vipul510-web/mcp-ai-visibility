# Required — public HTTPS origin of this deployment (no trailing slash)
PUBLIC_BASE_URL=https://www.example.com

# Required — Google OAuth Web client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional if PUBLIC_BASE_URL is set (defaults to {PUBLIC_BASE_URL}/api/auth/google/callback)
# GOOGLE_REDIRECT_URI=https://www.example.com/api/auth/google/callback

# Required — same secret used to sign browser session JWTs and MCP access/refresh tokens
JWT_SECRET=

# Required — 32+ bytes; used to encrypt Google refresh tokens at rest (AES-256-GCM)
ENCRYPTION_KEY=

# Required — Neon (or any Postgres) connection string used by @neondatabase/serverless
DATABASE_URL=

# Optional — display name shown in Claude’s MCP connector list (default: mcp-ga-gsc-seo)
# MCP_SERVER_DISPLAY_NAME=my-analytics-mcp

# Optional — URL returned in OAuth protected-resource metadata (default: {PUBLIC_BASE_URL}/)
# MCP_RESOURCE_DOCUMENTATION_URL=https://www.example.com/docs/mcp

# Optional — path to redirect after Google OAuth if no return_to cookie (default: /)
# MCP_POST_OAUTH_FALLBACK_PATH=/
