{
  "name": "aeo-visibility-mcp",
  "version": "1.0.0",
  "description": "MCP server for AI visibility and AEO (Answer Engine Optimization) analysis — connect via Claude or ChatGPT to analyze how your site ranks on AI platforms",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "aeo-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "@neondatabase/serverless": "^0.10.4",
    "axios": "^1.7.9",
    "cheerio": "^1.0.0",
    "express": "^4.21.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
