{
  "functions": {
    "api/audit.js": {
      "maxDuration": 30
    },
    "api/audit-site.js": {
      "maxDuration": 60
    },
    "api/feedback.js": {
      "maxDuration": 10
    },
    "api/feedback/test.js": {
      "maxDuration": 10
    },
    "api/feedback/list.js": {
      "maxDuration": 10
    },
    "api/generate-llm-txt.js": {
      "maxDuration": 30
    },
    "api/analyze-page.js": {
      "maxDuration": 30
    },
    "api/analyze-prompt-relevance.js": {
      "maxDuration": 60
    },
    "api/track-event.js": {
      "maxDuration": 10
    },
    "api/app.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/app" },
    { "source": "/api/auth/:path*", "destination": "/api/app" },
    { "source": "/api/user/:path*", "destination": "/api/app" },
    { "source": "/api/ga/:path*", "destination": "/api/app" },
    { "source": "/api/gsc/:path*", "destination": "/api/app" },
    { "source": "/api/mcp", "destination": "/api/app" },
    { "source": "/api/mcp/:path*", "destination": "/api/app" },
    { "source": "/.well-known/oauth-protected-resource", "destination": "/api/app" },
    { "source": "/.well-known/oauth-authorization-server", "destination": "/api/app" },
    { "source": "/.well-known/oauth-protected-resource/:path*", "destination": "/api/app" },
    { "source": "/.well-known/oauth-authorization-server/:path*", "destination": "/api/app" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        }
      ]
    }
  ]
}
